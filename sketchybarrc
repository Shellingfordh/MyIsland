#!/bin/bash

MODEL_NAME=$(sysctl -n hw.model)
ARCH=$(uname -m)

HAS_NOTCH=$(ioreg -n AppleType6Display | grep -i "display-subsystem-id" | wc -l)

CHECK_TOP_OCCUPIED=$(osascript -e 'tell application "System Events" to return exists (first process whose (name matches "(?i).*notch.*|.*island.*|.*dynamic.*|.*nook.*|.*land.*"))' 2>/dev/null)

# User overrides
USER_CONFIG="$HOME/.config/sketchybar/userconfig.sh"
if [ -f "$USER_CONFIG" ]; then
  # shellcheck disable=SC1090
  source "$USER_CONFIG"
fi

BAR_HEIGHT=40
ISLAND_BG_HEIGHT=36
CORNER_RADIUS=18
ICON_SIZE=16.0
LABEL_SIZE=15.0

ISLAND_Y_OFFSET=0
ICON_Y_CALIBRATION=0
LABEL_Y_CALIBRATION=0


if [[ "$ARCH" != "arm64" ]]; then
ICON_Y_CALIBRATION=-1
fi


if [[ $HAS_NOTCH -gt 0 ]]; then

BAR_HEIGHT=50
ISLAND_BG_HEIGHT=40
CORNER_RADIUS=20
ICON_SIZE=17
LABEL_SIZE=16

if [ "$CHECK_TOP_OCCUPIED" = "true" ]; then
ISLAND_Y_OFFSET=-52
else
ISLAND_Y_OFFSET=-1
fi

else

if [[ "$MODEL_NAME" == *"Air"* ]]; then
BAR_HEIGHT=38
ISLAND_BG_HEIGHT=32
CORNER_RADIUS=16
ISLAND_Y_OFFSET=-1
else
BAR_HEIGHT=42
ISLAND_BG_HEIGHT=35
CORNER_RADIUS=17
ISLAND_Y_OFFSET=-2
fi

if [ "$CHECK_TOP_OCCUPIED" = "true" ]; then
ISLAND_Y_OFFSET=-42
fi

fi

# Allow per-user pill height override
if [ -n "${USER_ISLAND_BG_HEIGHT:-}" ]; then
  ISLAND_BG_HEIGHT=$USER_ISLAND_BG_HEIGHT
  CORNER_RADIUS=$((ISLAND_BG_HEIGHT / 2))
fi

# Prevent pill clipping (ensure bar height >= pill height + margin)
BAR_HEIGHT=$((ISLAND_BG_HEIGHT + 12))
if [ -n "${USER_BAR_HEIGHT:-}" ]; then
  BAR_HEIGHT=$USER_BAR_HEIGHT
elif [ -n "${USER_BAR_EXTRA:-}" ]; then
  BAR_HEIGHT=$((BAR_HEIGHT + USER_BAR_EXTRA))
fi

ICON_Y_FINAL=$ICON_Y_CALIBRATION
LABEL_Y_FINAL=$LABEL_Y_CALIBRATION

# M1 Air fine-tune: move down by +4px total
if [[ "$MODEL_NAME" == "MacBookAir10,1" ]]; then
  ISLAND_Y_OFFSET=$((ISLAND_Y_OFFSET + 4))
  ICON_Y_FINAL=$((ICON_Y_FINAL + 4))
  LABEL_Y_FINAL=$((LABEL_Y_FINAL + 4))
fi

# Optional per-user offset tuning
if [ -n "${USER_ISLAND_Y_OFFSET_EXTRA:-}" ]; then
  ISLAND_Y_OFFSET=$((ISLAND_Y_OFFSET + USER_ISLAND_Y_OFFSET_EXTRA))
  ICON_Y_FINAL=$((ICON_Y_FINAL + USER_ISLAND_Y_OFFSET_EXTRA))
  LABEL_Y_FINAL=$((LABEL_Y_FINAL + USER_ISLAND_Y_OFFSET_EXTRA))
fi


sketchybar --remove '/.*/'

sketchybar --add event notification_occurrence
sketchybar --add event island_update


sketchybar --bar \
height=$BAR_HEIGHT \
position=top \
color=0x00000000 \
shadow=off \
border_width=0 \
topmost=on \
sticky=on \
show_in_fullscreen=on \
drawing=on \
ignore_mouse=on


sketchybar --add item island center

sketchybar --set island \
update_freq=2 \
drawing=on \
ignore_mouse=off \
z_index=999 \
script="$HOME/.config/sketchybar/plugins/island.sh" \
icon="💻" \
icon.font="Apple Color Emoji:Regular:$ICON_SIZE" \
icon.color=0xcd818cf8 \
icon.padding_left=15 \
icon.y_offset=$ICON_Y_FINAL \
label="Loading..." \
label.font="PingFang SC:Semibold:$LABEL_SIZE" \
label.color=0xcd818cf8 \
label.padding_right=18 \
label.y_offset=$LABEL_Y_FINAL \
background.color=0xff000000 \
background.height=$ISLAND_BG_HEIGHT \
background.corner_radius=$CORNER_RADIUS \
background.border_width=2 \
background.border_color=0xcd818cf8 \
background.drawing=on \
background.y_offset=$ISLAND_Y_OFFSET \
width=dynamic \
click_script="$HOME/.config/sketchybar/plugins/island.sh CLICK"


sketchybar --subscribe island \
front_app_switched \
display_change \
space_change \
system_woke \
notification_occurrence \
island_update


sketchybar --update
